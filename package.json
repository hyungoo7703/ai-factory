{
  "name": "ai-factory",
  "version": "0.1.0",
  "description": "Local AI development factory — git-native, worktree-isolated, self-improving multi-agent pipeline runner powered by Claude Code",
  "type": "module",
  "bin": {
    "factory": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "src/templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^10.2.2",
    "mammoth": "^1.8.0",
    "ora": "^8.1.0",
    "pdf-parse": "^1.1.1",
    "simple-git": "^3.27.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/pdf-parse": "^1.1.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
